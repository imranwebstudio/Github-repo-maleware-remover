GITHUB_PAT=ghp_replace_with_your_token
GITHUB_OWNER=your-org-or-user
GITHUB_REPO=your-repo
GITHUB_BRANCH=main

# Set to true to clean on a new branch and open a pull request.
CREATE_PR=false
DRY_RUN=false

# Optional. Used only when CREATE_PR=true.
PR_BRANCH=

# Web UI OAuth app settings.
# GitHub OAuth callback URL: http://localhost:3000/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SESSION_SECRET=replace_with_a_long_random_string
APP_BASE_URL=http://localhost:3000
PORT=3000
HOST=127.0.0.1
SCAN_REPO_CONCURRENCY=3
SCAN_FILE_CONCURRENCY=20
